<style>
:root{
  --bg:#080808;--bg2:#0D0D0D;--bg3:#111;
  --purple:#7C3AED;--purple2:#8B5CF6;--purple3:#A78BFA;--purple4:#6D28D9;
  --white:#fff;--gray:#9CA3AF;--gray2:#6B7280;
  --border:rgba(255,255,255,0.06);--border2:rgba(124,58,237,0.3);
  --glass:rgba(255,255,255,0.02);--glass2:rgba(124,58,237,0.08);
  --f:'Inter',sans-serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--white);font-family:var(--f);overflow-x:hidden;line-height:1.6;cursor:none;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--purple);border-radius:2px;}

#cursor{position:fixed;width:8px;height:8px;background:var(--purple2);border-radius:50%;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);}
#cursor-ring{position:fixed;width:32px;height:32px;border:1.5px solid rgba(139,92,246,0.5);border-radius:50%;pointer-events:none;z-index:99998;transform:translate(-50%,-50%);transition:left 0.1s,top 0.1s,width 0.3s,height 0.3s;}
#prog{position:fixed;top:0;left:0;height:2px;width:0%;background:linear-gradient(90deg,var(--purple),var(--purple3));z-index:100000;}

#nav{position:fixed;top:0;inset-x:0;z-index:10000;padding:1.5rem 0;transition:all 0.4s;}
#nav.scrolled{background:rgba(8,8,8,0.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:1rem 0;}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;}
.logo{font-size:1.2rem;font-weight:800;color:var(--white);text-decoration:none;letter-spacing:-0.02em;}
.logo span{color:var(--purple2);}
.nav-links{display:flex;align-items:center;gap:0.25rem;list-style:none;}
.nav-links a{color:var(--gray);font-size:0.85rem;font-weight:500;text-decoration:none;padding:0.5rem 1rem;border-radius:6px;transition:color 0.2s;}
.nav-links a:hover{color:var(--white);}
.nav-btns{display:flex;align-items:center;gap:0.75rem;}
.btn-outline{background:transparent;color:var(--white);padding:0.55rem 1.25rem;border-radius:8px;font-weight:600;font-size:0.85rem;text-decoration:none;border:1px solid var(--border2);transition:all 0.2s;font-family:var(--f);display:inline-block;}
.btn-outline:hover{background:var(--glass2);}
.btn-solid{background:var(--purple);color:#fff;padding:0.55rem 1.25rem;border-radius:8px;font-weight:600;font-size:0.85rem;text-decoration:none;border:none;cursor:pointer;transition:all 0.2s;font-family:var(--f);display:inline-block;}
.btn-solid:hover{background:var(--purple2);transform:translateY(-1px);box-shadow:0 8px 24px rgba(124,58,237,0.4);}
.mob-btn{display:none;background:none;border:1px solid var(--border);color:var(--white);width:38px;height:38px;border-radius:8px;cursor:pointer;font-size:1.1rem;align-items:center;justify-content:center;}
#mob-menu{display:none;position:fixed;inset:0;background:var(--bg);z-index:9999;flex-direction:column;align-items:center;justify-content:center;gap:2rem;}
#mob-menu.open{display:flex;}
#mob-menu a{font-size:2rem;font-weight:700;color:var(--white);text-decoration:none;}
#mob-menu a:hover{color:var(--purple2);}
.mob-close{position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;color:var(--white);font-size:1.5rem;cursor:pointer;}

#hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden;}
#vanta-bg{position:absolute;inset:0;width:100%;height:100%;z-index:0;}
.dome-glow{position:absolute;bottom:-120px;left:50%;transform:translateX(-50%);width:900px;height:520px;border-radius:50%;background:radial-gradient(circle at 50% 50%,rgba(160,80,255,0.95) 0%,rgba(130,50,240,0.7) 18%,rgba(100,20,210,0.4) 40%,transparent 70%);filter:blur(72px);pointer-events:none;z-index:1;}
.dome-core{position:absolute;bottom:-140px;left:50%;transform:translateX(-50%);width:420px;height:340px;border-radius:50%;background:radial-gradient(circle at 50% 40%,rgba(220,180,255,1) 0%,rgba(190,130,255,0.85) 22%,rgba(150,80,255,0.5) 48%,transparent 72%);filter:blur(40px);pointer-events:none;z-index:1;}
.dome-line{position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(200,150,255,0.5) 20%,rgba(255,240,255,0.9) 50%,rgba(200,150,255,0.5) 80%,transparent);z-index:2;}
.hero-inner{position:relative;z-index:10;max-width:820px;margin:0 auto;padding:160px 2rem 120px;}
.hero-tag{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.3);color:var(--purple3);font-size:0.7rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:0.4rem 1rem;border-radius:100px;margin-bottom:2rem;}
.htag-dot{width:5px;height:5px;background:var(--purple2);border-radius:50%;animation:blink 2s ease infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.3;}}
.hero-h1{font-size:clamp(2.8rem,5.5vw,5rem);font-weight:900;line-height:1.06;letter-spacing:-0.04em;margin-bottom:1.5rem;color:var(--white);}
.hero-h1 .accent{color:var(--purple2);}
.hero-p{font-size:1rem;color:var(--gray);line-height:1.8;max-width:520px;margin:0 auto 2.5rem;font-weight:400;}
.hero-btns{display:flex;align-items:center;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:3.5rem;}
.hero-btn-p{background:var(--purple);color:#fff;padding:0.88rem 2rem;border-radius:8px;font-weight:700;font-size:0.9rem;text-decoration:none;transition:all 0.25s;}
.hero-btn-p:hover{background:var(--purple2);transform:translateY(-2px);box-shadow:0 16px 40px rgba(124,58,237,0.45);}
.hero-btn-g{background:transparent;color:var(--white);padding:0.88rem 2rem;border-radius:8px;font-weight:600;font-size:0.9rem;text-decoration:none;border:1px solid rgba(255,255,255,0.12);transition:all 0.25s;}
.hero-btn-g:hover{border-color:rgba(255,255,255,0.25);background:rgba(255,255,255,0.04);}
.trust-bar{background:rgba(15,15,15,0.8);border:1px solid var(--border);border-radius:12px;padding:1.25rem 2.5rem;display:inline-flex;align-items:center;gap:0;flex-wrap:wrap;justify-content:center;}
.tb-stat{display:flex;flex-direction:column;gap:0.1rem;align-items:center;padding:0 2rem;}
.tb-stat+.tb-stat{border-left:1px solid var(--border);}
.tb-val{font-size:1.25rem;font-weight:800;color:var(--white);letter-spacing:-0.03em;line-height:1;}
.tb-lbl{font-size:0.62rem;color:var(--gray2);text-transform:uppercase;letter-spacing:0.1em;}
.tb-badges{display:flex;align-items:center;gap:1.5rem;padding:0 2rem;border-left:1px solid var(--border);flex-wrap:wrap;justify-content:center;}
.tb-badge{font-size:0.78rem;color:var(--gray);font-weight:500;display:flex;align-items:center;gap:0.3rem;}
.tb-badge span{color:var(--purple2);}

.section{padding:7rem 0;position:relative;}
.container{max-width:1200px;margin:0 auto;padding:0 2rem;}
.sec-center{text-align:center;max-width:620px;margin:0 auto 4rem;}
.s-tag{display:inline-block;font-size:0.62rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--purple2);margin-bottom:1rem;padding:0.28rem 0.7rem;background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.2);border-radius:4px;}
.s-title{font-size:clamp(1.9rem,3vw,2.8rem);font-weight:900;letter-spacing:-0.04em;line-height:1.1;margin-bottom:0.85rem;color:var(--white);}
.s-title .accent{color:var(--purple2);}
.s-sub{font-size:0.95rem;color:var(--gray);line-height:1.8;}

#about{background:var(--bg2);}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-bottom:4rem;}
.about-text{font-size:0.95rem;color:var(--gray);line-height:1.85;margin-bottom:1rem;}
.about-div{width:32px;height:2px;background:var(--purple);border-radius:2px;margin:1rem 0 1.5rem;}
.about-btns{display:flex;gap:0.85rem;margin-top:1.75rem;flex-wrap:wrap;}
.pillars{display:flex;flex-direction:column;gap:0.85rem;}
.pillar{background:var(--glass);border:1px solid var(--border);border-radius:12px;padding:1.25rem;display:flex;align-items:flex-start;gap:0.85rem;transition:all 0.3s;cursor:default;}
.pillar:hover{border-color:var(--border2);background:var(--glass2);transform:translateX(4px);}
.p-ico{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.15rem;background:rgba(124,58,237,0.1);}
.p-t{font-size:0.88rem;font-weight:700;color:var(--white);margin-bottom:0.2rem;}
.p-d{font-size:0.8rem;color:var(--gray);line-height:1.65;}
.stats-strip{display:grid;grid-template-columns:repeat(5,1fr);background:var(--purple4);border-radius:14px;padding:2rem 2.5rem;}
.sstat{text-align:center;padding:0 0.75rem;}
.sstat+.sstat{border-left:1px solid rgba(255,255,255,0.1);}
.sstat-v{font-size:1.9rem;font-weight:900;color:#fff;letter-spacing:-0.04em;display:block;line-height:1;}
.sstat-l{font-size:0.6rem;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.12em;font-weight:600;margin-top:0.4rem;display:block;}

#services{background:var(--bg);}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-top:3.5rem;}
.svc-card{background:var(--bg2);padding:2rem;transition:all 0.3s;cursor:default;position:relative;overflow:hidden;}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;border-radius:inherit;background:radial-gradient(600px circle at var(--mouse-x,0) var(--mouse-y,0),rgba(124,58,237,0.15),transparent 40%);opacity:0;transition:opacity 0.4s ease;pointer-events:none;z-index:0;}
.svc-card::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--purple2),transparent);opacity:0;transition:opacity 0.3s;}
.svc-card:hover{background:rgba(124,58,237,0.06);}
.svc-card:hover::before{opacity:1;}
.svc-card:hover::after{opacity:1;}
.svc-card>*{position:relative;z-index:1;}
.svc-card.featured-card{background:rgba(124,58,237,0.1);border-left:1px solid rgba(124,58,237,0.3);border-right:1px solid rgba(124,58,237,0.3);}
.svc-ico{width:44px;height:44px;border-radius:10px;background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.2);display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:1.25rem;}
.svc-arr{position:absolute;top:1.5rem;right:1.5rem;width:26px;height:26px;border:1px solid var(--border);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:var(--gray2);transition:all 0.3s;z-index:1;}
.svc-card:hover .svc-arr{border-color:var(--border2);color:var(--purple2);}
.svc-num{font-size:0.6rem;color:var(--gray2);font-weight:600;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.55rem;}
.svc-t{font-size:1rem;font-weight:700;color:var(--white);margin-bottom:0.55rem;}
.svc-d{font-size:0.82rem;color:var(--gray);line-height:1.7;}

#trust-band{background:var(--purple4);padding:5rem 0;}
.trust-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,0.08);border-radius:14px;overflow:hidden;margin-top:3rem;}
.tc{background:rgba(109,40,217,0.4);padding:2rem 1.5rem;text-align:center;}
.tc-n{font-size:2.5rem;font-weight:900;color:#fff;letter-spacing:-0.04em;display:block;line-height:1;margin-bottom:0.5rem;}
.tc-t{font-size:0.88rem;font-weight:700;color:#fff;margin-bottom:0.35rem;}
.tc-d{font-size:0.75rem;color:rgba(255,255,255,0.55);line-height:1.6;}

#process{background:var(--bg);}
.proc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;margin-top:3.5rem;}
.proc-step{background:var(--glass);border:1px solid var(--border);border-radius:14px;padding:1.75rem;transition:all 0.3s;cursor:default;position:relative;}
.proc-step:hover{border-color:var(--border2);background:var(--glass2);transform:translateY(-5px);}
.ps-n{font-size:2rem;font-weight:900;color:rgba(124,58,237,0.15);letter-spacing:-0.04em;line-height:1;margin-bottom:1rem;}
.ps-ico{width:40px;height:40px;border-radius:10px;background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.2);display:flex;align-items:center;justify-content:center;font-size:1.1rem;margin-bottom:1rem;}
.ps-t{font-size:0.92rem;font-weight:700;color:var(--white);margin-bottom:0.45rem;}
.ps-d{font-size:0.8rem;color:var(--gray);line-height:1.7;}
.ps-arr{position:absolute;top:1.5rem;right:1.5rem;width:26px;height:26px;border:1px solid var(--border);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:var(--gray2);}

#clients{background:var(--bg2);}
.ticker{overflow:hidden;border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:1rem 0;margin:2.5rem 0 3.5rem;}
.ticker-track{display:flex;animation:tick 28s linear infinite;width:max-content;}
.ticker-item{padding:0 2rem;border-right:1px solid var(--border);font-size:0.8rem;font-weight:600;white-space:nowrap;background:linear-gradient(90deg,var(--gray2) 0%,var(--gray2) 40%,var(--white) 50%,var(--gray2) 60%,var(--gray2) 100%);background-size:200% auto;color:transparent;-webkit-background-clip:text;background-clip:text;animation:shine 3s linear infinite;}
@keyframes shine{to{background-position:200% center;}}
@keyframes tick{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.cl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.1rem;margin-bottom:3rem;}
.cl-card{background:var(--glass);border:1px solid var(--border);border-radius:14px;padding:1.5rem;text-decoration:none;display:block;transition:all 0.3s;}
.cl-card:hover{border-color:var(--border2);transform:translateY(-4px);}
.cl-top{display:flex;align-items:center;gap:0.85rem;margin-bottom:0.85rem;}
.cl-av{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.78rem;color:#fff;flex-shrink:0;}
.cl-nm{font-size:0.88rem;font-weight:700;color:var(--white);margin-bottom:0.15rem;}
.cl-in{font-size:0.6rem;color:var(--gray2);text-transform:uppercase;letter-spacing:0.1em;font-weight:600;}
.cl-loc{font-size:0.75rem;color:var(--gray);margin-bottom:0.65rem;}
.cl-res{display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;font-weight:600;color:var(--purple2);background:rgba(124,58,237,0.07);padding:0.4rem 0.7rem;border-radius:6px;}
.testimonial{background:var(--glass);border:1px solid var(--border);border-radius:16px;padding:2.5rem;display:grid;grid-template-columns:1.4fr 1fr;gap:2.5rem;align-items:center;}
.test-q{font-size:1rem;color:rgba(255,255,255,0.82);line-height:1.8;font-style:italic;margin:0.75rem 0 1.25rem;}
.test-auth{display:flex;align-items:center;gap:0.65rem;}
.test-av{width:38px;height:38px;border-radius:50%;background:var(--purple);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.72rem;}
.test-nm{font-size:0.85rem;font-weight:700;color:var(--white);}
.test-rl{font-size:0.7rem;color:var(--gray);}
.pnums{display:flex;flex-direction:column;gap:1.25rem;}
.pn{padding-left:1rem;border-left:2px solid var(--purple2);}
.pn-v{font-size:1.6rem;font-weight:900;color:var(--white);letter-spacing:-0.04em;display:block;line-height:1;}
