.proj:hover::before{opacity:1;}
.proj>*{position:relative;z-index:1;}
.proj-bg-n{position:absolute;top:1rem;right:2rem;font-size:5rem;font-weight:900;color:rgba(124,58,237,0.04);line-height:1;pointer-events:none;}
.proj-tags{display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:0.6rem;}
