.pr-card:hover{transform:translateY(-5px);}
.pr-card.hot{border-color:rgba(124,58,237,0.4);background:rgba(124,58,237,0.04);transform:translateY(-12px);}
.pr-card.hot:hover{transform:translateY(-17px);}
.pr-card.hot::after{content:'';position:absolute;top:-15px;left:-15px;right:-15px;bottom:-15px;background:radial-gradient(circle at 50% 50%,rgba(124,58,237,0.4),transparent 70%);z-index:-1;border-radius:20px;filter:blur(25px);animation:pulse-glow 4s ease-in-out infinite;pointer-events:none;}
@keyframes pulse-glow{0%,100%{opacity:0.7;transform:scale(1);}50%{opacity:1.1;transform:scale(1.02);}}
.pr-badge{position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:var(--purple);color:#fff;font-size:0.58rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;padding:0.22rem 0.85rem;border-radius:100px;white-space:nowrap;}
.pr-tier{font-size:0.6rem;letter-spacing:0.15em;color:var(--gray2);text-transform:uppercase;margin-bottom:0.65rem;font-weight:600;}
.pr-amt{font-size:2.5rem;font-weight:900;color:var(--white);letter-spacing:-0.05em;margin-bottom:0.25rem;line-height:1;}
.pr-desc{font-size:0.8rem;color:var(--gray);margin-bottom:1.5rem;line-height:1.6;}
.pr-feats{display:flex;flex-direction:column;gap:0.6rem;margin-bottom:1.5rem;}
.pr-feat{display:flex;align-items:center;gap:0.5rem;font-size:0.83rem;color:rgba(255,255,255,0.72);}
.pr-chk{color:var(--purple2);flex-shrink:0;font-size:0.7rem;}
.pr-btn{display:block;text-align:center;padding:0.8rem;border-radius:8px;font-weight:700;font-size:0.85rem;text-decoration:none;transition:all 0.2s;font-family:var(--f);}
.pr-g{border:1px solid var(--border);color:rgba(255,255,255,0.65);}
.pr-g:hover{border-color:rgba(255,255,255,0.2);color:var(--white);}
.pr-f{background:var(--purple);color:#fff;}
.pr-f:hover{background:var(--purple2);box-shadow:0 10px 28px rgba(124,58,237,0.4);}

#contact{background:var(--bg);}
.ct-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;margin-top:3.5rem;align-items:start;}
.ct-item{display:flex;align-items:flex-start;gap:0.85rem;margin-bottom:1.25rem;}
.ct-ico{font-size:1rem;margin-top:2px;flex-shrink:0;}
.ct-lbl{font-size:0.6rem;color:var(--gray2);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.1rem;}
.ct-val{font-size:0.9rem;color:var(--white);font-weight:500;}
.fg{margin-bottom:1rem;}
.fl{display:block;font-size:0.6rem;font-weight:600;color:var(--gray2);margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.1em;}
.fi,.fs,.fta{width:100%;background:var(--glass);border:1px solid var(--border);border-radius:8px;padding:0.78rem 0.95rem;color:var(--white);font-size:0.88rem;font-family:var(--f);outline:none;transition:border-color 0.2s;}
.fi:focus,.fs:focus,.fta:focus{border-color:rgba(124,58,237,0.5);box-shadow:0 0 0 3px rgba(124,58,237,0.08);}
.fs option{background:var(--bg2);}
.fta{min-height:85px;resize:vertical;}
.fsub{width:100%;padding:0.9rem;background:var(--purple);color:#fff;border:none;border-radius:8px;font-size:0.92rem;font-weight:700;cursor:pointer;transition:all 0.25s;font-family:var(--f);}
.fsub:hover{background:var(--purple2);transform:translateY(-2px);box-shadow:0 12px 32px rgba(124,58,237,0.4);}

footer{background:var(--bg2);border-top:1px solid var(--border);padding:3.5rem 0 1.75rem;}
.ft-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:2.5rem;}
.ft-brand{font-size:0.82rem;color:var(--gray);line-height:1.75;margin-top:0.85rem;}
.ft-h{font-size:0.58rem;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:var(--gray2);margin-bottom:1.1rem;}
.ft-links{display:flex;flex-direction:column;gap:0.55rem;}
.ft-links a{font-size:0.82rem;color:rgba(255,255,255,0.4);text-decoration:none;transition:color 0.2s;}
.ft-links a:hover{color:var(--white);}
.ft-bot{border-top:1px solid var(--border);padding-top:1.35rem;display:flex;align-items:center;justify-content:space-between;}
.ft-copy{font-size:0.7rem;color:rgba(255,255,255,0.18);}

.reveal{opacity:0;transform:translateY(40px) scale(0.98);transition:all 0.8s cubic-bezier(0.16,1,0.3,1);}
.reveal.in{opacity:1;transform:translateY(0) scale(1);}
.reveal-l{opacity:0;transform:translateX(-40px) scale(0.98);transition:all 0.8s cubic-bezier(0.16,1,0.3,1);}
.reveal-l.in{opacity:1;transform:translateX(0) scale(1);}
.d1{transition-delay:0.08s;}.d2{transition-delay:0.15s;}.d3{transition-delay:0.22s;}.d4{transition-delay:0.3s;}

/* --- GLOBAL LIGHTING & DEPTH --- */
.global-light-1, .global-light-2, .global-light-3 {
  border-radius: 50%;
  pointer-events: none;
  filter: blur(140px);
  opacity: 0.35;
}
.gl-parallax {
  position: fixed; z-index: 0; pointer-events: none; transition: transform 0.1s linear;
}
.gl-p1 { top: -200px; left: -200px; }
.gl-p2 { bottom: -200px; right: -100px; }
.gl-p3 { top: 30%; left: 40%; }

.global-light-1 {
  width: 700px; height: 700px;
  background: rgba(124, 58, 237, 0.45);
  animation: float-light-1 20s ease-in-out infinite;
}
.global-light-2 {
  width: 600px; height: 600px;
  background: rgba(0, 229, 255, 0.35);
  animation: float-light-2 25s ease-in-out infinite;
}
.global-light-3 {
  width: 500px; height: 500px;
  background: rgba(236, 72, 153, 0.25);
  animation: float-light-3 22s ease-in-out infinite;
}

@keyframes float-light-1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(50px, 80px) scale(1.1); }
}
@keyframes float-light-2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-50px, -80px) scale(1.15); }
}
@keyframes float-light-3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(30px, -40px) scale(0.9); }
}

.noise-overlay {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
  pointer-events: none; z-index: 9998; opacity: 0.04;
  background: url('data:image/svg+xml;utf8,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
}
#particles-canvas {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
  pointer-events: none; z-index: 1;
}
section { position: relative; z-index: 2; }
#hero { z-index: 3; }
#about, #services, #clients, #portfolio, #pricing, #contact, #process, #trust-band {
  box-shadow: 0 -20px 60px rgba(0,0,0,0.5);
  background: transparent;
  backdrop-filter: blur(8px);
}
#about::before, #clients::before, #pricing::before {
  content:''; position:absolute; inset:0; background:var(--bg2); opacity:0.85; z-index:-1;
}
#services::before, #portfolio::before, #contact::before, #process::before {
  content:''; position:absolute; inset:0; background:var(--bg); opacity:0.85; z-index:-1;
}

#about {
  background: radial-gradient(circle at center, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
}
#services {
  background: radial-gradient(circle at top right, rgba(0, 229, 255, 0.1) 0%, transparent 60%);
}
#pricing {
  background: radial-gradient(circle at bottom center, rgba(236, 72, 153, 0.1) 0%, transparent 60%);
}

.pr-card.hot {
  position: relative;
  z-index: 1;
}
.pr-card.hot::after {
  content: ''; position: absolute; inset: -4px;
  background: linear-gradient(45deg, var(--purple), var(--purple3), #ec4899);
  border-radius: 16px; z-index: -1;
  filter: blur(12px); opacity: 0.85;
  animation: pulse-hot 2.5s infinite alternate;
}
@keyframes pulse-hot {
  0% { filter: blur(12px); opacity: 0.7; transform: scale(1); }
  100% { filter: blur(20px); opacity: 1; transform: scale(1.02); }
}

@media(max-width:1024px){
  .nav-links,.nav-btns{display:none;}.mob-btn{display:flex;}
  .about-grid{grid-template-columns:1fr;gap:2.5rem;}
  .svc-grid{grid-template-columns:repeat(2,1fr);}
  .trust-grid{grid-template-columns:repeat(2,1fr);}
  .proc-grid{grid-template-columns:repeat(2,1fr);}
  .cl-grid{grid-template-columns:repeat(2,1fr);}
  .testimonial{grid-template-columns:1fr;}
  .proj-body{grid-template-columns:1fr;}
  .pr-grid{grid-template-columns:1fr;}.pr-card.hot{transform:none;}
  .ct-grid{grid-template-columns:1fr;}
  .ft-grid{grid-template-columns:1fr 1fr;}
  .stats-strip{grid-template-columns:repeat(3,1fr);}
}
@media(max-width:640px){
  .svc-grid{grid-template-columns:1fr;}.cl-grid{grid-template-columns:1fr;}
  .trust-grid{grid-template-columns:1fr;}
  .stats-strip{grid-template-columns:repeat(2,1fr);}
  .ft-grid{grid-template-columns:1fr;}
  .ft-bot{flex-direction:column;gap:0.75rem;text-align:center;}
  .tb-badges{border-left:none;border-top:1px solid var(--border);padding-top:1rem;}
}
</style>
