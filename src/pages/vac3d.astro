.proj-bt{font-size:0.85rem;color:var(--gray);line-height:1.75;}
.proj-res{display:flex;gap:0.75rem;flex-wrap:wrap;padding-top:1.35rem;border-top:1px solid var(--border);}
.proj-r{display:flex;flex-direction:column;gap:0.1rem;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:0.75rem 1.1rem;min-width:90px;transition:all 0.25s;}
.proj-r:hover{border-color:var(--border2);transform:translateY(-3px);}
.proj-rv{font-size:1.5rem;font-weight:900;letter-spacing:-0.04em;line-height:1;}
.proj-rl{font-size:0.66rem;color:var(--gray);font-weight:600;}
.proj-lnk{display:inline-flex;align-items:center;gap:0.4rem;font-size:0.8rem;font-weight:700;color:var(--purple2);text-decoration:none;padding:0.5rem 1rem;border:1px solid rgba(124,58,237,0.25);border-radius:7px;transition:all 0.2s;margin-top:1rem;}
